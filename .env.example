# --- Supabase ---
# IMPORTANT: use the SESSION-mode pooler URL (port 5432), e.g.
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# The direct db host is IPv6-only and unreachable from Render.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
INBOX_BUCKET=inbox

# --- LLM (Google AI Studio free tier) ---
GOOGLE_API_KEY=
LLM_MODEL=gemini-flash-latest
LLM_MODEL_LITE=gemini-flash-lite-latest
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# --- Upstash Redis (REST) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Observability (LangSmith free) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentcapital-ai

# --- App ---
ENV=dev
LOG_LEVEL=INFO
